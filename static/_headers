# Cloudflare Pages response headers — https://developers.cloudflare.com/pages/configuration/headers/
# NOTE: these are applied by Cloudflare Pages only. `hugo server` does NOT serve them,
# so verify on the first deploy: browser DevTools > Network > (the document) > Headers.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # CSP calibrated to Congo's output on this site:
  #   - all JS is same-origin & fingerprinted, no inline <script>/handlers  -> script-src 'self' (no 'unsafe-inline')
  #   - 9 inline style="" attributes                                        -> style-src needs 'unsafe-inline' (style only)
  #   - video embeds                                                        -> frame-src youtube-nocookie + vimeo
  #   - img https: permits hotlinked images in posts; tighten to 'self' data: if you self-host every image
  # If you later use the katex / mermaid / chart shortcodes, those libs may need
  # script-src to add 'wasm-unsafe-eval' (or 'unsafe-eval') on pages that use them.
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self'; media-src 'self'; manifest-src 'self'; frame-src https://www.youtube-nocookie.com https://player.vimeo.com; upgrade-insecure-requests

# Fingerprinted (hashed) assets never change — cache them hard.
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable
